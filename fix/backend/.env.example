# Database — 5433 = Docker Compose `db` service on Windows when host 5432 is already taken.
# DATABASE_URL=postgresql://onyx:onyx@localhost:5432/onyx

DATABASE_URL=postgresql://onyx:onyx@localhost:5433/onyx

# Environment
ENV=development
LOG_LEVEL=INFO

# CORS (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
