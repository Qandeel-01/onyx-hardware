# Database — use port 5433 when Postgres runs via `docker compose up -d db` (host maps 5433->5432).
# Use 5432 if you installed PostgreSQL locally and created user/database `onyx`.
DATABASE_URL=postgresql://onyx:onyx@localhost:5433/onyx

# Environment
ENV=development
LOG_LEVEL=INFO

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
