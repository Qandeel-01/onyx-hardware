# Backend environment variables for bare-metal development

# Database
DATABASE_URL=postgresql+asyncpg://onyx:onyx_dev@localhost:5432/onyx

# JWT
SECRET_KEY=dev-secret-change-in-prod
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Clock sync
MAX_SYNC_SAMPLES_PER_BATCH=10
SYNC_INTERVAL_SECONDS=30

# Flash detection
FLASH_DETECTION_PROMINENCE=15.0
FLASH_DETECTION_MIN_DISTANCE_FRAMES=5
FLASH_EXPECTED_COUNT=3

# CV worker
CV_FRAME_SKIP=3
YOLO_MODEL_PATH=./backend/models/yolov8n-pose.pt
